@{
    ViewData["Title"] = "Home Page";
}

<section class="hero py-5">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6">

                <span class="text-uppercase small fw-bold span-hero">
                    Software de administración de alquileres
                </span>

                <h1 class="display-5 fw-bold mt-3">
                    Administrá tus propiedades <br> sin perder tiempo
                </h1>

                <p class="lead text-muted mt-3">
                    MiProp te permite gestionar edificios, contratos y pagos
                    de alquileres desde un solo lugar.
                    Simplificá tu administración inmobiliaria.
                </p>

                <div class="mt-4 d-flex gap-3">

                    <a class="btn btn-lg boton-primario px-4">
                        Solicitar demo
                    </a>

                    <a class="btn btn-lg boton-secundario px-4">
                        Ver funcionalidades
                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img src="~/imagenes/heroimg.png"
                     class="img-fluid"
                     style="max-height:420px">

            </div>

        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container text-center">

        <h2 class="fw-bold mb-5">
            Todo lo que necesitás para administrar alquileres
        </h2>

        <div class="row">

            <div class="col-md-4">

                <h4>
                    <i class="bi bi-check-circle text-orange fs-4 pe-2"></i>
                    Gestión de edificios
                </h4>
                <p class="text-muted">
                    Administrá múltiples edificios y unidades fácilmente.
                </p>
            </div>
            <div class="col-md-4">
                <h4>
                    <i class="bi bi-cash-stack text-orange fs-4 pe-2"></i>
                    Control de pagos</h4>
                <p class="text-muted">
                    Registrá pagos de alquileres y mantené todo organizado.
                </p>
            </div>

            <div class="col-md-4">
                <h4>
                    <i class="bi bi-people text-orange fs-4 pe-2"></i>
                    Panel para inquilinos</h4>
                <p class="text-muted">
                    Los inquilinos pueden consultar pagos y estados.
                </p>
            </div>

        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">

        <h2 class="text-center fw-bold mb-5">
            Funcionalidades principales
        </h2>

        <div class="row">

            <div class="col-md-6 mb-4">
                <h5>Gestión de contratos</h5>
                <p class="text-muted">
                    Control completo de contratos, vencimientos y renovaciones.
                </p>
            </div>

            <div class="col-md-6 mb-4">
                <h5>Registro de pagos</h5>
                <p class="text-muted">
                    Registrá pagos mensuales y llevá historial de cada unidad.
                </p>
            </div>

            <div class="col-md-6 mb-4">
                <h5>Administración de inquilinos</h5>
                <p class="text-muted">
                    Cada inquilino tiene su acceso al sistema.
                </p>
            </div>

            <div class="col-md-6 mb-4">
                <h5>Panel de administrador</h5>
                <p class="text-muted">
                    Visualizá todo desde un dashboard centralizado.
                </p>
            </div>

        </div>
    </div>
</section>


<section class="py-5">
    <div class="container">

        <h2 class="text-center fw-bold mb-5">
            Lo que dicen nuestros usuarios
        </h2>

        <div class="row">

            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <p>
                        "MiProp simplificó completamente la administración
                        de nuestros alquileres."
                    </p>
                    <strong>Juan Pérez</strong>
                    <br>
                    <small class="text-muted">Administrador</small>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <p>
                        "Ahora tenemos control total de pagos y contratos."
                    </p>
                    <strong>María Gómez</strong>
                    <br>
                    <small class="text-muted">Inmobiliaria</small>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm p-3">
                    <p>
                        "El panel para inquilinos es excelente."
                    </p>
                    <strong>Carlos Ruiz</strong>
                    <br>
                    <small class="text-muted">Propietario</small>
                </div>
            </div>

        </div>

    </div>
</section>

<section class="py-5 bg-light">
    <div class="container text-center">

        <h2 class="fw-bold mb-5">
            Planes simples
        </h2>

        <div class="row justify-content-center">

            <div class="col-md-4">

                <div class="card shadow p-4">

                    <h4>Starter</h4>

                    <h2 class="my-3">$10 / mes</h2>

                    <p class="text-muted">
                        Hasta 10 unidades
                    </p>

                    <button class="btn btn-primary w-100">
                        Comenzar
                    </button>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow p-4 border-primary">

                    <h4>Pro</h4>

                    <h2 class="my-3">$25 / mes</h2>

                    <p class="text-muted">
                        Unidades ilimitadas
                    </p>

                    <button class="btn btn-primary w-100">
                        Comenzar
                    </button>

                </div>

            </div>

        </div>

    </div>
</section>

<section class="py-5 text-center">
    <div class="container">

        <h2 class="fw-bold">
            Empezá a administrar tus alquileres hoy
        </h2>

        <p class="text-muted mb-4">
            Probá MiProp y simplificá tu gestión inmobiliaria.
        </p>

        <a class="btn btn-lg btn-primary px-5">
            Crear cuenta
        </a>

    </div>
</section>

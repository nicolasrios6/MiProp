@model Edificio

<h2>Crear Edificio</h2>

<div class="row justify-content-start mt-5">
    <form asp-action="Create" method="post" class="w-50">

        <div class="mb-3">
            <label>Nombre</label>
            <input asp-for="Nombre" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Dirección</label>
            <input asp-for="Direccion" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Admin</label>
            <select asp-for="AdminId" class="form-control">
                <option value="">-- Seleccionar --</option>
                @foreach (var admin in ViewBag.Admins)
                {
                    <option value="@admin.Id">@admin.Nombre @admin.Apellido</option>
                }
            </select>
        </div>

        <button type="submit" class="btn boton-primario">Guardar</button>
        <a asp-action="Index" asp-controller="Edificio" class="btn btn-secondary">Cancelar</a>
    </form>
</div>

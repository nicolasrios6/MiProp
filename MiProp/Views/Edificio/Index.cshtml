@model IEnumerable<Edificio>

<h2>Edificios</h2>

<a asp-action="Create" class="btn boton-primario mb-3">Crear Edificio</a>
<a asp-action="Dashboard" asp-controller="SuperAdmin" class="btn btn-secondary mb-3">Volver</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Dirección</th>
            <th>Admin</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Direccion</td>
                <td>@item.Admin?.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class=" btn btn-warning">Editar</a> 
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="modalErrorEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">No se puede eliminar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                @TempData["ErrorEliminarEdificio"]
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cerrar
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var error = '@TempData["ErrorEliminarEdificio"]';

            if (error) {
                var modal = new bootstrap.Modal(document.getElementById('modalErrorEliminar'));
                modal.show();
            }

        });
    </script>

}